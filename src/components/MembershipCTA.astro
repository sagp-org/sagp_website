---
import Icon from "./Icon.astro";
---

<section class="section membership-band">
  <div class="membership-content">
    <div class="membership-kicker">
      <Icon name="laurel" />
      <span class="kicker">Membership</span>
    </div>

    <h2>Become part of the conversation</h2>

    <p>
      Membership is open to scholars and students of Ancient Greek philosophy.
      Members support the Society’s events, scholarly community, and continuing work.
    </p>

    <p>
      <a class="button" href={`${import.meta.env.BASE_URL}/membership/`}>
        Learn about membership
      </a>
    </p>
  </div>
</section>
