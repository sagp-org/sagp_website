---
import "../styles/global.css";
import Icon from "../components/Icon.astro";
import ExecutiveGate from "../components/ExecutiveGate.astro";

const { title = "Society for Ancient Greek Philosophy" } = Astro.props;
const base = import.meta.env.BASE_URL;
const isExecutive = Astro.url.pathname.startsWith(`${base}/executive/`);
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
</head>
<body class:list={{ "executive-locked": isExecutive }}>
  <header class="site-header">
    <a class="brand" href={base}>
      <div class="brand-mark"><Icon name="column" /></div>
      <div class="brand-text">
        <div class="brand-acronym">SAGP</div>
        <div class="brand-name">Society for Ancient<br />Greek Philosophy</div>
      </div>
    </a>

    <nav>
      <a href={base}>Home</a>
      <a href={`${base}/who-we-are/`}>Who We Are</a>
      <a href={`${base}/events/`}>Events</a>
      <a href={`${base}/governance/`}>Governance</a>
      <a href={`${base}/membership/`}>Membership</a>
      <a href={`${base}/contact/`}>Contact</a>
      <a href={`${base}/executive/`}>Executive</a>
    </nav>
  </header>

  {isExecutive && <ExecutiveGate />}

  <main
    id={isExecutive ? "executive-content" : undefined}
    inert={isExecutive ? true : undefined}
    aria-hidden={isExecutive ? "true" : undefined}
  >
    <slot />
  </main>

  <footer class="site-footer">
    <p>© 2025 Society for Ancient Greek Philosophy. All rights reserved.</p>
    <p>
      <a href={`${base}/contact/`}>Contact</a>
      <a href={`${base}/executive/`}>Executive</a>
    </p>
  </footer>

  <script>
    const header = document.querySelector(".site-header");

    function updateHeader() {
      header?.classList.toggle("scrolled", window.scrollY > 12);
    }

    updateHeader();
    window.addEventListener("scroll", updateHeader);
  </script>
</body>
</html>
