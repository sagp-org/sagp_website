---
import SAGPLayout from "../../../layouts/SAGPLayout.astro";
import PageHero from "../../../components/PageHero.astro";
---

<SAGPLayout title="New Call | SAGP Executive Portal">

<PageHero
  kicker="Executive Portal"
  title="New Call"
  subtitle="Future workflow: upload or paste a call document and generate canonical call YAML."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section two-col">
  <div><h2>Planned workflow</h2></div>
  <div>
    <ol>
      <li>Upload or paste source content.</li>
      <li>AI extracts title, deadlines, eligibility, contact, and submission instructions.</li>
      <li>AI drafts canonical YAML.</li>
      <li>Executive reviewer approves or edits.</li>
      <li>System publishes website, email, and PDF outputs.</li>
    </ol>
  </div>
</section>

</SAGPLayout>
