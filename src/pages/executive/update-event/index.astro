---
import SAGPLayout from "../../../layouts/SAGPLayout.astro";
import PageHero from "../../../components/PageHero.astro";
---

<SAGPLayout title="Update Event | SAGP Executive Administration">

<PageHero
  kicker="Publishing Workspace"
  title="Update Event"
  subtitle="Edit canonical publication facts for an existing event."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section two-col">
  <div>
    <h2>Selected Event</h2>
  </div>

  <div>
    <div id="event-status" class="callout">
      Loading selected event...
    </div>
  </div>
</section>

<section class="section">
  <article class="card">
    <form id="event-form" class="event-form">
      <div id="event-detail">
        Event details will appear here.
      </div>

      <div id="event-editor-actions" class="editor-actions hidden">
        <label for="update-reason">Reason for update</label>
        <input
          id="update-reason"
          type="text"
          placeholder="Corrected date, updated Zoom instructions, revised title, etc."
        />

        <button class="button" id="prepare-publication-update" type="button" disabled>
          Prepare Publication Update
        </button>

        <pre id="update-preview" class="preview">
Make changes above, then enter a reason for the update.
        </pre>
      </div>
    </form>
  </article>
</section>

</SAGPLayout>

<script>
  import {
    EVENT_UPDATE_FIELDS,
    getNestedValue,
    collectEventChanges,
    validateEventForm,
  } from "../../../lib/publishing/update_event.js";

  import {
    buildPublicationUpdateRequest,
    downloadPublicationUpdate,
  } from "../../../lib/publishing/publication_update_request.js";

  let selectedEvent = null;

  function platformUrl(path) {
    const base = "/sagp_website";
    const cleanPath = String(path).replace(/^\//, "");
    return `${base}/${cleanPath}`;
  }

  function display(value) {
    return value || "";
  }

  function fieldInput(field, event) {
    const value = display(getNestedValue(event, field.key));

    if (field.type === "textarea") {
      return `
        <label>${field.label}</label>
        <textarea data-event-field="${field.key}" rows="6">${value}</textarea>
      `;
    }

    return `
      <label>${field.label}</label>
      <input
        data-event-field="${field.key}"
        type="${field.type}"
        value="${value}"
      />
    `;
  }

  async function loadPublishingIndex() {
    const response = await fetch(`${platformUrl("/platform/publishing_index.json")}?v=${Date.now()}`);
    if (!response.ok) {
      throw new Error(`Could not load publishing index: ${response.status}`);
    }
    return response.json();
  }

  function updatePreview() {
    const preview = document.querySelector("#update-preview");
    const button = document.querySelector("#prepare-publication-update");
    const reason = document.querySelector("#update-reason").value.trim();

    if (!selectedEvent) return;

    const changes = collectEventChanges(selectedEvent);
    const errors = validateEventForm();

    if (errors.length) {
      preview.textContent = [
        "Please correct these problems:",
        "",
        ...errors.map((error) => `- ${error}`),
      ].join("\n");
      button.disabled = true;
      return;
    }

    if (Object.keys(changes).length === 0) {
      preview.textContent = "Make changes above, then enter a reason for the update.";
      button.disabled = true;
      return;
    }

    const lines = [
      `Event: ${selectedEvent.title}`,
      `Publication ID: ${selectedEvent.id}`,
      "",
      "Changes to be reviewed:",
      ...Object.entries(changes).map(([field, value]) => `- ${field}: ${value || "(blank)"}`),
      "",
      reason ? `Reason: ${reason}` : "Reason is required before preparing the update.",
    ];

    preview.textContent = lines.join("\n");
    button.disabled = !reason;
  }

  function renderEvent(event) {
    selectedEvent = event;

    const status = document.querySelector("#event-status");
    const detail = document.querySelector("#event-detail");
    const actions = document.querySelector("#event-editor-actions");

    status.innerHTML = `
      <strong>${event.title}</strong><br />
      ${event.type} · ${event.year} · ${event.status || "status not specified"}
    `;

    detail.innerHTML = `
      <h2>${event.title}</h2>

      <div class="metadata">
        <strong>Event ID:</strong> ${event.event_id}<br />
        <strong>Publication ID:</strong> ${event.id}<br />
        <strong>Source YAML:</strong> ${event.source_yaml}
      </div>

      <div class="form-grid">
        ${EVENT_UPDATE_FIELDS.map((field) => fieldInput(field, event)).join("")}
      </div>
    `;

    actions.classList.remove("hidden");

    for (const element of detail.querySelectorAll("input, textarea")) {
      element.addEventListener("input", updatePreview);
    }

    document.querySelector("#update-reason").addEventListener("input", updatePreview);

    document.querySelector("#prepare-publication-update").addEventListener("click", () => {
      const reason =
        document.querySelector("#update-reason").value.trim();

      const changes = collectEventChanges(selectedEvent);

      const request = buildPublicationUpdateRequest({
        publicationType: "event",
        publicationId: selectedEvent.id,
        originalObject: selectedEvent,
        changes,
        reason,
      });

      downloadPublicationUpdate(request);
    });
  }

  const params = new URLSearchParams(window.location.search);
  const selectedId = params.get("id");

  loadPublishingIndex()
    .then((index) => {
      if (!selectedId) {
        document.querySelector("#event-status").textContent =
          "No event selected. Return to the Publishing Workspace and choose an event.";
        return;
      }

      const event = (index.events ?? []).find((item) => item.id === selectedId);

      if (!event) {
        document.querySelector("#event-status").textContent =
          `Could not find event: ${selectedId}`;
        return;
      }

      renderEvent(event);
    })
    .catch((error) => {
      document.querySelector("#event-status").textContent = error.message;
    });
</script>

<style>
.event-form h2 {
  margin-top: 0;
}

.metadata {
  margin: 1rem 0 1.5rem;
  padding: 1rem;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  background: #fffaf0;
  color: var(--color-muted);
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}

.event-form label {
  display: block;
  margin-top: 0.75rem;
  font-weight: 700;
}

.event-form input,
.event-form textarea {
  width: 100%;
  padding: 0.85rem;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  background: #fffaf0;
  color: var(--color-text);
  font: inherit;
}

.event-form textarea {
  resize: vertical;
}

.editor-actions {
  margin-top: 28px;
  padding-top: 20px;
  border-top: 1px solid var(--color-border);
}

.hidden {
  display: none;
}

button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.preview {
  white-space: pre-wrap;
  background: #fffaf0;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 1rem;
  color: var(--color-text);
  margin-top: 1rem;
}
</style>
