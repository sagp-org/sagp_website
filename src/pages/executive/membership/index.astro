---
import SAGPLayout from "../../../layouts/SAGPLayout.astro";
import PageHero from "../../../components/PageHero.astro";
---

<SAGPLayout title="Membership Workspace | SAGP Executive Portal">

<PageHero
  kicker="Executive Portal"
  title="Membership Workspace"
  subtitle="View the current membership profile and operational membership status."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section">
  <div class="dashboard-grid">
    <article class="stat-card">
      <p>Total members</p>
      <strong id="total-members">—</strong>
    </article>

    <article class="stat-card">
      <p>Members with email</p>
      <strong id="members-with-email">—</strong>
    </article>

    <article class="stat-card">
      <p>Current paid members</p>
      <strong id="current-paid-members">—</strong>
    </article>

    <article class="stat-card">
      <p>Expired members</p>
      <strong id="expired-members">—</strong>
    </article>

    <article class="stat-card">
      <p>Paid / renewed this year</p>
      <strong id="paid-this-year">—</strong>
    </article>

    <article class="stat-card">
      <p>Not renewed this year</p>
      <strong id="not-renewed-this-year">—</strong>
    </article>
  </div>
</section>

<section class="section create-member-section">
  <article class="card">
    <div class="workflow-heading">
      <div>
        <p class="eyebrow">New membership</p>
        <h2>Create New Member</h2>
        <p class="muted">Enter the member’s information. This prepares a request for review; it does not change the membership database.</p>
      </div>
    </div>

    <form id="create-member-form" class="create-member-form">
      <label>First name <span aria-hidden="true">*</span>
        <input id="create-first-name" name="first_name" type="text" maxlength="120" required autocomplete="given-name" />
      </label>
      <label>Last name <span aria-hidden="true">*</span>
        <input id="create-last-name" name="last_name" type="text" maxlength="120" required autocomplete="family-name" />
      </label>
      <label>Email
        <input id="create-primary-email" name="primary_email" type="email" maxlength="254" autocomplete="email" />
      </label>
      <label>Institution
        <input id="create-institution" name="institution" type="text" maxlength="300" autocomplete="organization" />
      </label>
      <label>Region
        <input id="create-region" name="region" type="text" maxlength="120" />
      </label>
      <label>Membership expiration year <span aria-hidden="true">*</span>
        <input id="create-expiration-year" name="membership_expiration_year" type="number" min="1900" max="2100" step="1" inputmode="numeric" required />
      </label>
      <label class="wide-field">Notes
        <textarea id="create-notes" name="notes" rows="4" maxlength="4000"></textarea>
      </label>
      <label class="wide-field">Reason or context <span aria-hidden="true">*</span>
        <input id="create-reason" name="reason" type="text" maxlength="500" required placeholder="New member joined; payment received; etc." />
      </label>
    </form>

    <div class="create-actions">
      <button class="button" id="prepare-membership-create" type="button" disabled>
        Prepare New Member Request
      </button>
      <span class="muted">* Required</span>
    </div>
    <pre id="create-preview" class="preview" aria-live="polite">Complete the required fields to prepare a new-member request.</pre>
  </article>
</section>

<section class="section member-lookup">
  <article class="card">
    <h2>Find Member</h2>
    <p class="muted">Search by name, institution, email, region, status, or paid year.</p>

    <input id="member-search" type="search" placeholder="Search members..." />

    <div id="member-results" class="member-results">
      Type to search member records.
    </div>
  </article>

  <article class="card member-detail-card">
    <h2>Member Record</h2>
    <div id="member-detail" class="member-detail">
      Select a member to view the record.
    </div>

    <div id="member-editor" class="member-editor hidden">
      <h3>Edit Member</h3>

      <label>Email</label>
      <input id="edit-primary-email" type="email" />

      <label>Institution</label>
      <input id="edit-institution" type="text" />

      <label>Region</label>
      <input id="edit-region" type="text" />

      <label>Expiration Year</label>
      <input id="edit-expiration-year" type="text" />

      <label>Notes</label>
      <textarea id="edit-notes" rows="6"></textarea>

      <label>Reason for update</label>
      <input id="edit-reason" type="text" placeholder="Renewed through 2028; corrected email; etc." />

      <button class="button" id="prepare-membership-update" disabled>
        Prepare Membership Update
      </button>

      <pre id="update-preview" class="preview">Make changes above, then enter a reason for the update.</pre>
    </div>
  </article>


</section>

<section class="section two-col">
  <div>
    <h2>Status profile</h2>
    <p class="muted" id="generated-at">Loading membership dashboard...</p>
  </div>

  <div class="card">
    <h3>Membership status counts</h3>
    <table>
      <thead>
        <tr>
          <th>Status</th>
          <th>Count</th>
        </tr>
      </thead>
      <tbody id="status-table"></tbody>
    </table>
  </div>
</section>

</SAGPLayout>

<script>
  const fmt = new Intl.NumberFormat("en-US");

  function setText(id, value) {
    document.querySelector(`#${id}`).textContent = fmt.format(value ?? 0);
  }

  function platformUrl(path) {
    const base = "/sagp_website";
    const cleanPath = String(path).replace(/^\//, "");
    return `${base}/${cleanPath}`;
  }

  async function loadDashboard() {
    const response = await fetch(`${platformUrl("/platform/membership_dashboard.json")}?v=${Date.now()}`);
    if (!response.ok) {
      throw new Error(`Could not load membership dashboard: ${response.status}`);
    }
    return response.json();
  }

  function renderStatusTable(counts) {
    const tbody = document.querySelector("#status-table");
    tbody.innerHTML = "";

    for (const [status, count] of Object.entries(counts ?? {})) {
      const row = document.createElement("tr");
      row.innerHTML = `<td>${status}</td><td>${fmt.format(count)}</td>`;
      tbody.appendChild(row);
    }
  }

  let memberRecords = [];
  let selectedMember = null;

  function createMemberData() {
    return {
      first_name: document.querySelector("#create-first-name").value.trim(),
      last_name: document.querySelector("#create-last-name").value.trim(),
      primary_email: document.querySelector("#create-primary-email").value.trim(),
      institution: document.querySelector("#create-institution").value.trim(),
      region: document.querySelector("#create-region").value.trim(),
      notes: document.querySelector("#create-notes").value.trim(),
      membership_expiration_year: document.querySelector("#create-expiration-year").value.trim(),
    };
  }

  function buildMembershipCreate() {
    const form = document.querySelector("#create-member-form");
    const reason = document.querySelector("#create-reason").value.trim();
    if (!form.checkValidity() || !reason) return null;
    return {
      proposed_member_data: createMemberData(),
      reason,
      requested_by: "executive_portal",
      request_type: "membership_create",
      request_id: `mcr_${crypto.randomUUID().replaceAll("-", "").slice(0, 12)}`,
      requested_at: new Date().toISOString(),
      source: "executive_portal_static",
      notes: null,
    };
  }

  function updateCreatePreview() {
    const form = document.querySelector("#create-member-form");
    const button = document.querySelector("#prepare-membership-create");
    const data = createMemberData();
    const reason = document.querySelector("#create-reason").value.trim();
    button.disabled = !form.checkValidity() || !reason;
    if (button.disabled) {
      document.querySelector("#create-preview").textContent = "Complete the required fields with a valid email and expiration year to prepare a new-member request.";
      return;
    }
    const expiration = Number(data.membership_expiration_year);
    const status = expiration >= new Date().getFullYear() - 1 ? "Current Member" : "Past Member";
    document.querySelector("#create-preview").textContent = [
      `New member: ${data.first_name} ${data.last_name}`,
      `Email: ${data.primary_email || "(not supplied)"}`,
      `Institution: ${data.institution || "(not supplied)"}`,
      `Region: ${data.region || "(not supplied)"}`,
      `Expiration year: ${data.membership_expiration_year}`,
      `Membership status: ${status} (derived)`,
      `Reason: ${reason}`,
      "",
      "Edward will review this request and check for duplicate records before creation.",
    ].join("\n");
  }

  function memberEmail(member) {
    return member.primary_email || member.secondary_email || "";
  }

  function renderMemberResults(members) {
    const container = document.querySelector("#member-results");

    if (!members.length) {
      container.textContent = "No matching members.";
      return;
    }

    container.innerHTML = "";

    for (const member of members.slice(0, 50)) {
      const button = document.createElement("button");
      button.className = "member-result";
      button.type = "button";

      button.innerHTML = `
        <strong>${member.display_name || "(No name)"}</strong>
        <span>${member.institution || ""}</span>
        <span>${member.membership_status || "(No status)"}${member.last_paid_year ? ` · Last paid ${member.last_paid_year}` : ""}</span>
      `;

      button.addEventListener("click", () => renderMemberDetail(member));
      container.appendChild(button);
    }

    if (members.length > 50) {
      const more = document.createElement("p");
      more.className = "muted";
      more.textContent = `Showing first 50 of ${members.length.toLocaleString()} matches. Refine the search to narrow results.`;
      container.appendChild(more);
    }
  }

  function setEditorValues(member) {
    selectedMember = member;

    document.querySelector("#member-editor").classList.remove("hidden");
    document.querySelector("#edit-primary-email").value = member.primary_email || "";
    document.querySelector("#edit-institution").value = member.institution || "";
    document.querySelector("#edit-region").value = member.region || "";
    document.querySelector("#edit-expiration-year").value =
      member.membership_expiration_year || member.last_paid_year || "";
    document.querySelector("#edit-notes").value = member.notes || "";
    document.querySelector("#edit-reason").value = "";
    document.querySelector("#update-preview").textContent = "Make changes above, then enter a reason for the update.";
    document.querySelector("#prepare-membership-update").disabled = true;
  }

  function proposedChangesFromEditor() {
    if (!selectedMember) return {};

    const fields = {
      primary_email: document.querySelector("#edit-primary-email").value.trim(),
      institution: document.querySelector("#edit-institution").value.trim(),
      region: document.querySelector("#edit-region").value.trim(),
      membership_expiration_year: document.querySelector("#edit-expiration-year").value.trim(),
      notes: document.querySelector("#edit-notes").value.trim(),
    };

    const original = {
      primary_email: selectedMember.primary_email || "",
      institution: selectedMember.institution || "",
      region: selectedMember.region || "",
      membership_expiration_year:
        selectedMember.membership_expiration_year || selectedMember.last_paid_year || "",
      notes: selectedMember.notes || "",
    };

    const changes = {};
    for (const [field, value] of Object.entries(fields)) {
      if (value !== original[field]) {
        changes[field] = value;
      }
    }

    return changes;
  }

  function buildMembershipUpdate() {
    const changes = proposedChangesFromEditor();
    const reason = document.querySelector("#edit-reason").value.trim();

    if (!selectedMember || Object.keys(changes).length === 0 || !reason) {
      return null;
    }

    return {
      person_id: selectedMember.person_id,
      proposed_changes: changes,
      reason,
      requested_by: "executive_portal",
      request_id: `mur_${crypto.randomUUID().replaceAll("-", "").slice(0, 12)}`,
      requested_at: new Date().toISOString(),
      source: "executive_portal_static",
      notes: null,
    };
  }

  function updateRequestPreview() {
    const changes = proposedChangesFromEditor();
    const reason = document.querySelector("#edit-reason").value.trim();
    const button = document.querySelector("#prepare-membership-update");

    if (!selectedMember) return;

    if (Object.keys(changes).length === 0) {
      document.querySelector("#update-preview").textContent = "Make changes above, then enter a reason for the update.";
      button.disabled = true;
      return;
    }

    const lines = [
      `Member: ${selectedMember.display_name}`,
      `Person ID: ${selectedMember.person_id}`,
      "",
      "Changes to be reviewed:",
      ...Object.entries(changes).map(([field, value]) => `- ${field}: ${value}`),
      "",
      reason ? `Reason: ${reason}` : "Reason is required before preparing the update.",
    ];

    document.querySelector("#update-preview").textContent = lines.join("\n");
    button.disabled = !reason;
  }

  function renderMemberDetail(member) {
    const container = document.querySelector("#member-detail");

    container.innerHTML = `
      <div class="record-header">
        <h3>${member.display_name || "(No name)"}</h3>
        <p>${member.institution || ""}</p>
      </div>

      <dl class="record-grid">
        <dt>Person ID</dt><dd>${member.person_id || ""}</dd>
        <dt>Email</dt><dd>${memberEmail(member)}</dd>
        <dt>Phone</dt><dd>${member.phone || ""}</dd>
        <dt>Location</dt><dd>${[member.city, member.state_province, member.country].filter(Boolean).join(", ")}</dd>
        <dt>Region</dt><dd>${member.region || ""}</dd>
        <dt>Derived Status</dt><dd>${member.derived_membership_status || ""}</dd>
        <dt>Stored Status</dt><dd>${member.membership_status || ""}</dd>
        <dt>Original Code</dt><dd>${member.original_membership_code || ""}</dd>
        <dt>Member Since</dt><dd>${member.member_since || ""}</dd>
        <dt>Expiration Year</dt><dd>${member.membership_expiration_year || member.last_paid_year || ""}</dd>
        <dt>Active</dt><dd>${member.active || ""}</dd>
        <dt>Updated</dt><dd>${member.updated_at || ""}</dd>
      </dl>

      <h4>Notes</h4>
      <pre class="preview">${member.notes || ""}</pre>
    `;

    setEditorValues(member);
  }

  async function loadMemberRecords() {
    const response = await fetch(`${platformUrl("/platform/membership_records.json")}?v=${Date.now()}`);
    if (!response.ok) {
      throw new Error(`Could not load member records: ${response.status}`);
    }

    const payload = await response.json();
    memberRecords = payload.members ?? [];

    const search = document.querySelector("#member-search");
    const results = document.querySelector("#member-results");

    results.textContent = `${memberRecords.length.toLocaleString()} member records loaded. Type to search.`;

    search.addEventListener("input", () => {
      const query = search.value.trim().toLowerCase();

      if (!query) {
        results.textContent = `${memberRecords.length.toLocaleString()} member records loaded. Type to search.`;
        return;
      }

      const terms = query.split(/\s+/).filter(Boolean);
      const matches = memberRecords.filter((member) =>
        terms.every((term) => member.search_text.includes(term))
      );

      renderMemberResults(matches);
    });
  }

  for (const id of [
    "edit-primary-email",
    "edit-institution",
    "edit-region",
    "edit-expiration-year",
    "edit-notes",
    "edit-reason",
  ]) {
    document.addEventListener("input", (event) => {
      if (event.target?.id === id) updateRequestPreview();
    });
  }

  document.querySelector("#create-member-form").addEventListener("input", updateCreatePreview);

  document.addEventListener("click", (event) => {
    if (event.target?.id === "prepare-membership-create") {
      const request = buildMembershipCreate();
      if (!request) return;
      const blob = new Blob([JSON.stringify(request, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      const safeLastName = request.proposed_member_data.last_name
        .toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_+|_+$/g, "") || "member";
      link.download = `membership_create_${safeLastName}_${request.request_id}.json`;
      link.click();
      URL.revokeObjectURL(url);
      return;
    }
    if (event.target?.id !== "prepare-membership-update") return;

    const request = buildMembershipUpdate();
    if (!request) return;

    const blob = new Blob(
      [JSON.stringify(request, null, 2)],
      { type: "application/json" }
    );

    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    const safeName = selectedMember.display_name
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, "_")
      .replace(/^_+|_+$/g, "");

    link.download = `membership_update_${safeName}_${request.request_id}.json`;
    link.click();
    URL.revokeObjectURL(url);
  });

  loadDashboard()
    .then((dashboard) => {
      const summary = dashboard.summary ?? {};

      setText("total-members", summary.total_members);
      setText("members-with-email", summary.members_with_email);
      setText("current-paid-members", summary.current_paid_members);
      setText("expired-members", summary.expired_members);
      setText("paid-this-year", summary.paid_or_renewed_this_year);
      setText("not-renewed-this-year", summary.not_renewed_this_year);

      document.querySelector("#generated-at").textContent =
        `Generated ${dashboard.generated_at}; source: ${dashboard.source_database}`;

      renderStatusTable(dashboard.membership_status_counts);
      loadMemberRecords().catch((error) => {
        document.querySelector("#member-results").textContent = error.message;
      });
    })
    .catch((error) => {
      document.querySelector("#generated-at").textContent = error.message;
    });
</script>

<style>
.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.create-member-section .card {
  max-width: 1050px;
  margin-inline: auto;
}

.workflow-heading h2,
.workflow-heading p {
  margin-top: 0;
}

.eyebrow {
  color: #8a5a13;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.create-member-form {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem 1.25rem;
  margin-top: 1.5rem;
}

.create-member-form label {
  display: grid;
  gap: 0.4rem;
  font-weight: 650;
}

.create-member-form input,
.create-member-form textarea {
  width: 100%;
  box-sizing: border-box;
}

.wide-field {
  grid-column: 1 / -1;
}

.create-actions {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 1.25rem 0 1rem;
}

.button:disabled {
  cursor: not-allowed;
  opacity: 0.55;
}

.hidden {
  display: none;
}

.stat-card {
  background: #fffaf0;
  border: 1px solid var(--color-border);
  border-radius: 18px;
  padding: 22px;
}

.stat-card p {
  margin: 0 0 10px;
  color: var(--color-muted);
}

.stat-card strong {
  font-size: 2.4rem;
  line-height: 1;
}

table {
  width: 100%;
  border-collapse: collapse;
}

td,
th {
  padding: 0.65rem 0;
  border-bottom: 1px solid var(--color-border);
  text-align: left;
}

@media (max-width: 900px) {
  .dashboard-grid {
    grid-template-columns: 1fr;
  }

  .create-member-form {
    grid-template-columns: 1fr;
  }

  .wide-field {
    grid-column: auto;
  }

}
</style>
