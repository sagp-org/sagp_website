---
import SAGPLayout from "../../../layouts/SAGPLayout.astro";
import PageHero from "../../../components/PageHero.astro";
---

<SAGPLayout title="Secretary Instructions | SAGP Executive Administration">

<PageHero
  kicker="Executive Administration"
  title="Secretary Instructions"
  subtitle="Workflow instructions for preparing SAGP membership and publication updates."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section">
  <article class="card instructions">
    <h2>Membership Updates</h2>

    <ol>
      <li>Open the <strong>Membership Workspace</strong>.</li>
      <li>Find the member.</li>
      <li>Make the necessary changes.</li>
      <li>Enter a brief reason for the update.</li>
      <li>Click <strong>Prepare Membership Update</strong>.</li>
      <li>A JSON update file will download to your <strong>Downloads</strong> folder.</li>
      <li>
        Send an email to Edward with subject line
        <strong>SAGP Membership Update</strong>.
      </li>
      <li>Attach the downloaded JSON file.</li>
      <li>No further action is required.</li>
    </ol>

    <h2>Publication Updates</h2>

    <ol>
      <li>Open the <strong>Publishing Workspace</strong>.</li>
      <li>Select the Event or Call that needs to be updated.</li>
      <li>Click <strong>Update Selected Event</strong> or <strong>Update Selected Call</strong>.</li>
      <li>Make the necessary changes.</li>
      <li>Enter a brief reason for the update.</li>
      <li>Click <strong>Prepare Publication Update</strong>.</li>
      <li>A JSON update file will download to your <strong>Downloads</strong> folder.</li>
      <li>
        Send an email to Edward with subject line
        <strong>SAGP Publication Update</strong>.
      </li>
      <li>Attach the downloaded JSON file.</li>
      <li>No further action is required.</li>
    </ol>
  </article>
</section>

</SAGPLayout>

<style>
.instructions {
  max-width: 900px;
}

.instructions h2 {
  margin-top: 0;
}

.instructions h2 + ol {
  margin-bottom: 2.5rem;
}

.instructions li {
  margin: 0.55rem 0;
}
</style>
