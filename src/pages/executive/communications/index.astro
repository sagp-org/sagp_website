---
import SAGPLayout from "../../../layouts/SAGPLayout.astro";
import PageHero from "../../../components/PageHero.astro";
---

<SAGPLayout title="Communications Workspace | SAGP Executive Portal">

<PageHero
  kicker="Executive Portal"
  title="Communications Workspace"
  subtitle="Prepare an email package by choosing an audience and writing or selecting a message."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section communication-builder">
  <article class="card">
    <p class="kicker">Step 1</p>
    <h3>Choose Audience</h3>
    <select id="audience-select">
      <option value="">Loading audiences...</option>
    </select>
    <pre id="audience-preview" class="preview">No audience selected.</pre>
  </article>

  <article class="card">
    <p class="kicker">Step 2</p>
    <h3>Choose Message</h3>

    <label>
      <input type="radio" name="message-mode" value="saved" checked />
      Use saved message
    </label>

    <select id="message-select">
      <option value="">Loading messages...</option>
    </select>

    <label>
      <input type="radio" name="message-mode" value="compose" />
      Compose message now
    </label>

    <label for="custom-title">Message title</label>
    <input id="custom-title" type="text" placeholder="Membership renewal reminder" />

    <label for="custom-subject">Subject</label>
    <input id="custom-subject" type="text" placeholder="Please renew your SAGP membership" />

    <label for="custom-body">Message body</label>
    <textarea id="custom-body" rows="8" placeholder="Write the message Betsy wants to send..."></textarea>

    <pre id="message-preview" class="preview">No message selected.</pre>
  </article>

  <div class="actions">
    <button class="button" id="compose-button" disabled>Compose Communication</button>
    <button class="button" id="copy-emails-button" disabled>Copy Email Addresses</button>
    <button class="button" id="copy-subject-button" disabled>Copy Subject</button>
    <button class="button" id="copy-body-button" disabled>Copy Plain Text</button>
    <button class="button" id="copy-rich-html-button" disabled>Copy Rich HTML</button>
    <button class="button" id="download-button" disabled>Download Communication JSON</button>
  </div>

  <article class="card">
    <p class="kicker">Step 3</p>
    <h3>Preview Communication</h3>
    <pre id="communication-preview" class="preview">No communication composed.</pre>

    <h4>Rich Text Preview</h4>
    <iframe id="rich-html-preview" class="rich-preview" title="Rich text preview"></iframe>
  </article>
</section>

</SAGPLayout>

<script>
  let manifest = null;
  let audience = null;
  let message = null;
  let communication = null;

  const audienceSelect = document.querySelector("#audience-select");
  const messageSelect = document.querySelector("#message-select");
  const composeButton = document.querySelector("#compose-button");
  const downloadButton = document.querySelector("#download-button");
  const copyEmailsButton = document.querySelector("#copy-emails-button");
  const copySubjectButton = document.querySelector("#copy-subject-button");
  const copyBodyButton = document.querySelector("#copy-body-button");
  const copyRichHtmlButton = document.querySelector("#copy-rich-html-button");

  const audiencePreview = document.querySelector("#audience-preview");
  const messagePreview = document.querySelector("#message-preview");
  const communicationPreview = document.querySelector("#communication-preview");
  const richHtmlPreview = document.querySelector("#rich-html-preview");

  const customTitle = document.querySelector("#custom-title");
  const customSubject = document.querySelector("#custom-subject");
  const customBody = document.querySelector("#custom-body");

  function makeId(prefix) {
    return `${prefix}_${crypto.randomUUID().replaceAll("-", "").slice(0, 12)}`;
  }

  function nowIso() {
    return new Date().toISOString();
  }

  function selectedMessageMode() {
    return document.querySelector('input[name="message-mode"]:checked')?.value ?? "saved";
  }

  function updateButtons() {
    const canCompose = audience && message;
    composeButton.disabled = !canCompose;

    const hasCommunication = !!communication;
    downloadButton.disabled = !hasCommunication;
    copyEmailsButton.disabled = !hasCommunication;
    copySubjectButton.disabled = !hasCommunication;
    copyBodyButton.disabled = !hasCommunication;
    copyRichHtmlButton.disabled = !hasCommunication;
  }

  function fillSelect(select, items, emptyLabel) {
    select.innerHTML = "";

    const empty = document.createElement("option");
    empty.value = "";
    empty.textContent = emptyLabel;
    select.appendChild(empty);

    for (const item of items) {
      const option = document.createElement("option");
      option.value = item.url;
      option.textContent = `${item.title} — ${item.detail}`;
      select.appendChild(option);
    }
  }

  async function loadJson(url) {
    const response = await fetch(url);
    if (!response.ok) throw new Error(`Could not load ${url}: ${response.status}`);
    return response.json();
  }

  async function loadManifest() {
    manifest = await loadJson(`${import.meta.env.BASE_URL}/platform/platform_manifest.json`);

    fillSelect(audienceSelect, manifest.audiences ?? [], "Choose an audience...");
    fillSelect(messageSelect, manifest.messages ?? [], "Choose a saved message...");
  }

  function resetCommunication() {
    communication = null;
    communicationPreview.textContent = "No communication composed.";
    richHtmlPreview.srcdoc = "";
    updateButtons();
  }

  function buildCustomMessage() {
    const title = customTitle.value.trim() || "Custom message";
    const subject = customSubject.value.trim();
    const body = customBody.value.trim();

    if (!subject || !body) {
      message = null;
      messagePreview.textContent = "Enter both a subject and message body.";
      updateButtons();
      return;
    }

    message = {
      title,
      subject,
      rich_html: `<p>${body.replaceAll("\n\n", "</p><p>").replaceAll("\n", "<br />")}</p>`,
      plain_text: body,
      source_yaml: null,
      message_type: "custom",
      attachments_or_links: [],
      message_id: makeId("msg"),
      generated_at: nowIso(),
      source_engine: "executive_portal",
    };

    messagePreview.textContent = [
      `Title: ${message.title}`,
      `Subject: ${message.subject}`,
      `Type: custom`,
      "",
      message.plain_text,
    ].join("\n");

    updateButtons();
  }

  audienceSelect.addEventListener("change", async () => {
    resetCommunication();

    if (!audienceSelect.value) {
      audience = null;
      audiencePreview.textContent = "No audience selected.";
      updateButtons();
      return;
    }

    audience = await loadJson(`${import.meta.env.BASE_URL}${audienceSelect.value.replace(/^\//, "")}`);

    audiencePreview.textContent = [
      `Name: ${audience.name}`,
      `Recipients: ${audience.recipients?.length ?? 0}`,
      `Description: ${audience.description}`,
      "",
      "Criteria:",
      JSON.stringify(audience.criteria ?? {}, null, 2),
    ].join("\n");

    updateButtons();
  });

  messageSelect.addEventListener("change", async () => {
    resetCommunication();
    document.querySelector('input[name="message-mode"][value="saved"]').checked = true;

    if (!messageSelect.value) {
      message = null;
      messagePreview.textContent = "No saved message selected.";
      updateButtons();
      return;
    }

    message = await loadJson(`${import.meta.env.BASE_URL}${messageSelect.value.replace(/^\//, "")}`);

    messagePreview.textContent = [
      `Title: ${message.title}`,
      `Subject: ${message.subject}`,
      `Type: ${message.message_type ?? ""}`,
      "",
      "Plain text:",
      message.plain_text ?? "",
      "",
      "Rich HTML is available and will appear in the rich-text preview after composing.",
    ].join("\n");

    updateButtons();
  });

  for (const input of [customTitle, customSubject, customBody]) {
    input.addEventListener("input", () => {
      resetCommunication();
      document.querySelector('input[name="message-mode"][value="compose"]').checked = true;
      buildCustomMessage();
    });
  }

  document.querySelectorAll('input[name="message-mode"]').forEach((radio) => {
    radio.addEventListener("change", () => {
      resetCommunication();
      if (selectedMessageMode() === "compose") {
        buildCustomMessage();
      }
    });
  });

  composeButton.addEventListener("click", () => {
    if (selectedMessageMode() === "compose") buildCustomMessage();
    if (!audience || !message) return;

    communication = {
      communication_id: makeId("com"),
      created_at: nowIso(),
      created_by: "executive_portal",
      delivery_status: "draft",
      delivery_metadata: {},
      audit_notes: [],
      audience,
      message,
    };

    communicationPreview.textContent = [
      `Recipients: ${audience.recipients?.length ?? 0}`,
      `Audience: ${audience.name}`,
      `Subject: ${message.subject}`,
      "",
      "Plain text message:",
      message.plain_text ?? "",
    ].join("\n");

    richHtmlPreview.srcdoc = message.rich_html ?? "";

    updateButtons();
  });

  copyEmailsButton.addEventListener("click", async () => {
    const emails = communication.audience.recipients.map((r) => r.email).filter(Boolean).join(", ");
    await navigator.clipboard.writeText(emails);
  });

  copySubjectButton.addEventListener("click", async () => {
    await navigator.clipboard.writeText(communication.message.subject);
  });

  copyBodyButton.addEventListener("click", async () => {
    await navigator.clipboard.writeText(communication.message.plain_text);
  });

  copyRichHtmlButton.addEventListener("click", async () => {
    const html = communication.message.rich_html ?? "";
    const plain = communication.message.plain_text ?? "";

    if (window.ClipboardItem) {
      const item = new ClipboardItem({
        "text/html": new Blob([html], { type: "text/html" }),
        "text/plain": new Blob([plain], { type: "text/plain" }),
      });
      await navigator.clipboard.write([item]);
    } else {
      await navigator.clipboard.writeText(html);
    }
  });

  downloadButton.addEventListener("click", () => {
    if (!communication) return;

    const blob = new Blob(
      [JSON.stringify(communication, null, 2)],
      { type: "application/json" }
    );

    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");

    link.href = url;
    link.download = `${communication.communication_id}.json`;
    link.click();

    URL.revokeObjectURL(url);
  });

  loadManifest().catch((error) => {
    audienceSelect.innerHTML = `<option value="">Could not load audiences</option>`;
    messageSelect.innerHTML = `<option value="">Could not load messages</option>`;
    communicationPreview.textContent = error.message;
  });
</script>

<style>
.communication-builder {
  max-width: 1000px;
}

.card + .card {
  margin-top: 24px;
}

.actions {
  display: flex;
  gap: 12px;
  margin: 24px 0;
  flex-wrap: wrap;
}

.preview {
  white-space: pre-wrap;
  background: #fffaf0;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 1rem;
  min-height: 100px;
  overflow-x: auto;
}

label {
  display: block;
  margin-top: 1rem;
  font-weight: 600;
}

select,
input[type="text"],
textarea {
  width: 100%;
  padding: 0.8rem;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  background: #fffaf0;
  color: var(--color-text);
  font: inherit;
  margin: 0.4rem 0 1rem;
}

textarea {
  resize: vertical;
}

button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.rich-preview {
  width: 100%;
  min-height: 420px;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  background: white;
}
</style>
