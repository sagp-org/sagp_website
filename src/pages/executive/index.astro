---
import SAGPLayout from "../../layouts/SAGPLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<SAGPLayout title="Executive Administration | SAGP">

<PageHero
  kicker="Executive Administration"
  title="SAGP Executive Administration"
  subtitle="Operational tools for administering the Society."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section">
  <div class="portal-intro">
    <p>
      The Executive Administration Portal supports the operational work of the
      Society by turning completed organizational work into canonical knowledge
      and derived publications, communications, and membership views.
    </p>
  </div>

  <div class="portal-grid">
    <article class="card feature-card">
      <h3>Communication Workspace</h3>
      <p>
        Combine audiences with messages, preview rich-text communications, and
        prepare complete communication packages.
      </p>
      <p>
        <a class="button" href={`${import.meta.env.BASE_URL}/executive/communications/`}>
          Open Workspace →
        </a>
      </p>
    </article>

    <article class="card feature-card">
      <h3>Membership Workspace</h3>
      <p>
        View membership statistics, find members, prepare membership updates,
        and publish refreshed membership information.
      </p>
      <p>
        <a class="button" href={`${import.meta.env.BASE_URL}/executive/membership/`}>
          Open Workspace →
        </a>
      </p>
    </article>

    <article class="card feature-card">
      <h3>Publishing Workspace</h3>
      <p>
        Maintain events, calls for papers, and other Society publications from
        canonical content.
      </p>
      <p>
        <a class="button" href={`${import.meta.env.BASE_URL}/executive/publishing/`}>
          Open Workspace →
        </a>
      </p>
    </article>
  </div>

  <div class="instruction-buttons">
    <a class="button secondary" href={`${import.meta.env.BASE_URL}/executive/instructions/secretary/`}>
      Secretary Instructions
    </a>
    <a class="button secondary" href={`${import.meta.env.BASE_URL}/executive/instructions/sysadmin/`}>
      SysAdmin Instructions
    </a>
  </div>
</section>

</SAGPLayout>

<style>
.portal-intro {
  max-width: 860px;
  margin-bottom: 28px;
  font-size: 1.1rem;
  color: var(--color-muted);
}

.portal-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 24px;
}

.feature-card {
  min-height: 260px;
}

@media (max-width: 1000px) {
  .instruction-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 28px;
  margin: 42px 0 0;
  justify-content: center;
}

.portal-grid {
    grid-template-columns: 1fr;
  }
}
</style>
