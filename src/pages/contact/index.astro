---
import PageHero from "../../components/PageHero.astro";
import SAGPLayout from "../../layouts/SAGPLayout.astro";
---

<SAGPLayout title="Contact | Society for Ancient Greek Philosophy">

<PageHero
  kicker="Contact"
  title="The conversation continues here."
  subtitle="Whether you are interested in joining the Society, attending an event, presenting your work, or learning more about SAGP, we would be glad to hear from you."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section two-col">
  <div>
    <h2>General inquiries</h2>
  </div>

  <div>
    <p>
      For questions about the Society, membership, events, or participation,
      please contact the SAGP Secretary.
    </p>

    <div class="callout">
      <strong>Tony Preus</strong><br>
      Secretary Emeritus<br><br>
      <a href="mailto:apreus@binghamton.edu">apreus@binghamton.edu</a>
    </div>
  </div>
</section>

<section class="section">
  <h2>Common reasons to get in touch</h2>

  <div class="card-grid">
    <article class="card">
      <h3>Membership</h3>
      <p>
        Ask about joining SAGP, renewing membership, or arranging payment from
        outside the United States.
      </p>
    </article>

    <article class="card">
      <h3>Events</h3>
      <p>
        Ask about attending the Annual Conference, Distinguished Lectureship,
        Works in Progress series, or SAGP-sponsored panels.
      </p>
    </article>

    <article class="card">
      <h3>Participation</h3>
      <p>
        Ask about presenting work, submitting abstracts, or becoming more
        involved in the Society’s scholarly community.
      </p>
    </article>
  </div>
</section>

<section class="section two-col">
  <div>
    <h2>Begin with a conversation</h2>
  </div>

  <div>
    <p>
      SAGP began with a conversation among scholars in 1952. More than seventy
      years later, the Society continues to grow through conversations among
      students, scholars, officers, members, and friends of Ancient Greek
      philosophy.
    </p>

    <p>
      If you are not sure where to begin, simply write and ask.
    </p>
  </div>
</section>

</SAGPLayout>
