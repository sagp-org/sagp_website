---
import PageHero from "../../../components/PageHero.astro";
import SAGPLayout from "../../../layouts/SAGPLayout.astro";
import EventCollection from "../../../components/events/EventCollection.astro";
import { loadEvents } from "../../../lib/content/index.js";

const lectures = loadEvents("distinguished_lectureship");
const recentLectures = lectures.slice(0, 3);
---

<SAGPLayout title="Distinguished Lectureship | SAGP">

<PageHero
  kicker="Distinguished Lectureship"
  title="Honoring major contributions to Ancient Greek philosophy."
  subtitle="The SAGP Distinguished Lectureship recognizes scholars whose work has shaped the field."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section two-col">
  <div>
    <h2>What is the Distinguished Lectureship?</h2>
  </div>

  <div>
    <p>
      The Distinguished Lectureship honors scholars whose work has made
      substantial and lasting contributions to the study of Ancient Greek
      philosophy.
    </p>

    <p>
      The lecture provides an occasion for the Society to recognize influential
      scholarship and to gather around a major contribution to the field.
    </p>
  </div>
</section>

<section class="section">
  <h2>Recent Distinguished Lectures</h2>

  <EventCollection
    events={recentLectures}
    basePath="/events/distinguished-lectureship"
  />
</section>

<section class="section two-col">
  <div>
    <h2>Lecture Archive</h2>
  </div>

  <div>
    <p>
      The recent lectureship archive preserves a record of scholars honored by
      SAGP for significant contributions to the field.
    </p>

    <p>
      <a href={`${import.meta.env.BASE_URL}/events/distinguished-lectureship/archive/`}>
        View the full lecture archive →
      </a>
    </p>
  </div>
</section>

</SAGPLayout>
