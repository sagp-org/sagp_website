---
import PageHero from "../../../../components/PageHero.astro";
import SAGPLayout from "../../../../layouts/SAGPLayout.astro";
import EventCollection from "../../../../components/events/EventCollection.astro";
import { loadEvents } from "../../../../lib/events.js";

const lectures = loadEvents("distinguished_lectureship");
---

<SAGPLayout title="Distinguished Lectureship Archive | SAGP">

<PageHero
  kicker="Archive"
  title="Distinguished Lectureship archive."
  subtitle="A record of scholars honored by SAGP for significant contributions to Ancient Greek philosophy."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section">
  <h2>Recent lectures</h2>

  <EventCollection
    events={lectures}
    basePath="/events/distinguished-lectureship"
  />
</section>

<section class="section two-col">
  <div>
    <h2>A record of recognition</h2>
  </div>

  <div>
    <p>
      The Distinguished Lectureship archive preserves the Society’s recognition
      of scholars whose work has shaped the study of Ancient Greek philosophy.
    </p>
  </div>
</section>

</SAGPLayout>
