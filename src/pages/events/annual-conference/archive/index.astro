---
import PageHero from "../../../../components/PageHero.astro";
import SAGPLayout from "../../../../layouts/SAGPLayout.astro";
import EventCollection from "../../../../components/events/EventCollection.astro";
import { loadEvents } from "../../../../lib/content/index.js";

const conferences = loadEvents("annual_conference");
---

<SAGPLayout title="Annual Conference Archive | SAGP">

<PageHero
  kicker="Archive"
  title="Annual Conference archive."
  subtitle="A record of recent SAGP annual conferences."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section">
  <h2>Recent conferences</h2>

  <EventCollection
    events={conferences}
    basePath="/events/annual-conference"
    label="conference"
  />
</section>

</SAGPLayout>
