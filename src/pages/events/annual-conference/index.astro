---
import PageHero from "../../../components/PageHero.astro";
import SAGPLayout from "../../../layouts/SAGPLayout.astro";
import EventCollection from "../../../components/events/EventCollection.astro";
import { loadEvents } from "../../../lib/content/index.js";

const conferences = loadEvents("annual_conference");
const currentConference = conferences[0];
---

<SAGPLayout title="Annual Conference | SAGP">

<PageHero
  kicker="Annual Conference"
  title="The Society’s annual gathering for scholarly exchange."
  subtitle="The Annual Conference brings together scholars for themed sessions, discussion, and international participation."
  image="/assets/images/parthenon_night.jpg"
/>

<section class="section two-col">
  <div>
    <h2>What is the Annual Conference?</h2>
  </div>
  <div>
    <p>
      The Annual Conference is the Society’s central yearly gathering, bringing
      together scholars for themed sessions, moderated discussion, and original
      research in Ancient Greek philosophy.
    </p>
  </div>
</section>

<section class="section">
  <h2>Current conference</h2>

  <EventCollection
    events={[currentConference]}
    basePath="/events/annual-conference"
    label="conference"
  />
</section>

<section class="section two-col">
  <div>
    <h2>Conference archive</h2>
  </div>
  <div>
    <h3>Recent conferences</h3>
    <p>
      The recent conference archive preserves the Society’s annual conferences as part of
      its developing scholarly record.
    </p>
    <p>
      <a href={`${import.meta.env.BASE_URL}/events/annual-conference/archive/`}>
        View the recent conference archive →
      </a>
    </p>

    <h3>Historical SAGP archive</h3>
    <p>
      For earlier conference programs, papers, and records from the Society’s
      history, visit the SAGP archive maintained at Binghamton University.
    </p>
    <p>
      <a href="https://orb.binghamton.edu/sagp/" target="_blank" rel="noreferrer">
        View the historical SAGP archive →
      </a>
    </p>
  </div>
</section>

</SAGPLayout>
