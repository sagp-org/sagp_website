---
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";

import PageHero from "../../../../components/PageHero.astro";
import EventProgram from "../../../../components/EventProgram.astro";
import SAGPLayout from "../../../../layouts/SAGPLayout.astro";

const file = path.resolve("content/events/annual_conference_2025.yaml");
const data = yaml.load(fs.readFileSync(file, "utf8"));
const event = data.event;
---

<SAGPLayout title={`${event.title} | SAGP`}>
  <PageHero
    kicker={event.title}
    title={event.subtitle}
    subtitle={`${event.dates.start}–${event.dates.end} · ${event.location.venue} · ${event.dates.timezone}`}
    image={event.hero_image}
  />

  <EventProgram event={event} />
</SAGPLayout>
