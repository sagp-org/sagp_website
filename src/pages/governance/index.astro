---
import SAGPLayout from "../../layouts/SAGPLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { loadGovernance } from "../../lib/content/index.js";

const leadership = loadGovernance("leadership");
const bylaws = loadGovernance("bylaws");
---

<SAGPLayout title="Governance | Society for Ancient Greek Philosophy">

<PageHero
  kicker="Governance"
  title="How the Society is organized."
  subtitle="Officers, board members, and bylaws of the Society for Ancient Greek Philosophy."
  image="/assets/images/delphi_treasury.jpg"
/>

<section class="section two-col">
  <div>
    <h2>Leadership</h2>
    <p class="muted">{leadership.summary}</p>
  </div>

  <div>
    <div class="people-grid officers">
      {leadership.officers.map((person) => (
        <article class="person-card officer">
          <img
            src={`${import.meta.env.BASE_URL}/assets/images/people/${person.image}`}
            alt={person.name}
          />

          <h3>{person.name}</h3>

          <p class="role">{person.role}</p>

          <p class="affiliation">{person.affiliation}</p>
        </article>
      ))}
    </div>

    <h2 style="margin-top:4rem;">Board of Directors</h2>

    <div class="people-grid board">
      {leadership.board_members.map((person) => (
        <article class="person-card">
          <img
            src={`${import.meta.env.BASE_URL}/assets/images/people/${person.image}`}
            alt={person.name}
          />

          <h3>{person.name}</h3>

          <p class="affiliation">{person.affiliation}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section two-col">
  <div>
    <h2>{bylaws.title}</h2>
  </div>

  <div>
    <p>{bylaws.summary}</p>

    <p>
      <a class="button" href={`${import.meta.env.BASE_URL}/governance/bylaws/`}>
        View the bylaws
      </a>
    </p>
  </div>
</section>



<style>
.people-grid{
    display:grid;
    gap:2rem;
}

.people-grid.officers{
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    margin-top:2rem;
}

.people-grid.board{
    grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
    margin-top:2rem;
}

.person-card{
    text-align:center;
}

.person-card img{
    width:140px;
    height:140px;
    object-fit:cover;
    border-radius:50%;
    border:4px solid var(--color-border);
    margin-bottom:1rem;
}

.officer img{
    width:170px;
    height:170px;
}

.person-card h3{
    margin:.5rem 0;
}

.role{
    color:var(--color-accent);
    font-weight:600;
    margin-bottom:.4rem;
}

.affiliation{
    color:var(--color-muted);
    font-size:.95rem;
    line-height:1.4;
}
</style>


</SAGPLayout>
